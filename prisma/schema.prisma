// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventTier {
  verified
  suggested
}

enum EventCategory {
  anchor
  trigger
}

enum TriggerResponseStatus {
  confirmed
  dismissed
}

enum AIMessageRole {
  user
  assistant
}

enum TokenOrderStatus {
  pending
  paid
  failed
  canceled
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // domain fields
  birthYear Int?
  region    String?

  // explicit consent timestamps (Phase 3.3)
  termsConsentAt            DateTime?
  privacyConsentAt          DateTime?
  overseasTransferConsentAt DateTime?

  // Phase 4.5: marks the user as done with onboarding (completed or
  // fully skipped). Used to soft-route new users to /onboarding only once.
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())

  accounts          Account[]
  sessions          Session[]
  profile           LifeProfile?
  memories          UserMemory[]
  triggerResponses  TriggerResponse[]
  conversations     AIConversation[]
  wallet            TokenWallet?
  tokenTxs          TokenTransaction[]
  tokenOrders       TokenOrder[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LifeProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id])
  interests    String[]
  schools      String[]
  residences   String[]
  parentsInfo  String?
  siblings     String?
  closeFriends String?
  hobbies      String?
  favMovies    String[]
  favGames     String[]
  favMusic     String[]
  updatedAt    DateTime @updatedAt
}

// embedding is a pgvector(1024) column matching voyage-3.5 output.
// Prisma can't express the vector type natively, so it's Unsupported —
// day-to-day reads/writes go through raw SQL (see lib/triggers.ts).
model Event {
  id          String                       @id @default(cuid())
  year        Int
  month       Int?
  title       String
  description String?
  tier        EventTier
  category    EventCategory
  domain      String
  region      String                       @default("KR")
  sourceName  String?
  sourceUrl   String?
  createdAt   DateTime                     @default(now())
  embedding         Unsupported("vector(1024)")?
  memories          UserMemory[]
  triggerResponses  TriggerResponse[]
  conversations     AIConversation[]

  @@index([year])
}

// Phase 8.2 — paid token wallet. balance is a cached running total
// that MUST equal SUM(tokenTxs.delta) for the same userId; every
// mutation is done inside a $transaction that updates both rows
// together. reconcileBalance() in lib/tokens/wallet.ts checks the
// invariant on demand for audits.
// ⚠️ Every read / write is userId-scoped. signup grant is idempotent
// — wallet's @unique(userId) is the gate.
model TokenWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int      // signed: +grant/topup/refund, -ai_charge
  reason    String   // "signup_grant" | "ai_charge" | "topup" | "refund"
  refId     String?  // payment id, AI message id, etc.
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Phase 8.5 — top-up order tracking. id doubles as the orderId we
// send to Toss. Amount + tokens are recorded at PENDING create from
// the server-side package definition, so the client can't bend either
// later. paymentKey @unique means the same Toss payment cannot be
// settled twice.
model TokenOrder {
  id          String           @id @default(cuid())
  userId      String
  user        User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  packageId   String
  krw         Int
  tokens      Int
  status      TokenOrderStatus @default(pending)
  paymentKey  String?          @unique
  approvedAt  DateTime?
  failedAt    DateTime?
  failReason  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

// Phase 7.5 — persisted memory conversation per (user, event). The
// first assistant message holds the AI-generated guided questions;
// later messages alternate user answers and (optionally) follow-up
// assistant replies. Reloading /memory/[eventId] reuses the same
// conversation so the user sees the same questions.
// ⚠️ All reads MUST scope by userId.
model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]

  @@unique([userId, eventId])
  @@index([userId])
}

model AIMessage {
  id              String         @id @default(cuid())
  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            AIMessageRole
  content         String
  inputTokens     Int?
  outputTokens    Int?
  // Phase 8.3 — null = not yet settled against the wallet. Charge is
  // done per memory cycle (guided + summary together), so multiple
  // assistant messages may flip from null → now() in one transaction.
  chargedAt       DateTime?
  createdAt       DateTime       @default(now())

  @@index([conversationId])
}

// Phase 6.8 — per-user response to a suggested trigger event.
// confirmed = user keeps it on the timeline (Phase 7 will hang
// memories off these), dismissed = hide from future suggestions.
// ⚠️ Every read MUST scope by userId; never expose another user's row.
model TriggerResponse {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status    TriggerResponseStatus
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, eventId])
  @@index([userId])
}

// Memories default to private. Phase 9 will introduce shared visibility
// ("family", etc.); every read path MUST scope by userId until then.
model UserMemory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id])
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id])
  year       Int
  month      Int?
  title      String
  content    String?
  visibility String   @default("private")
  createdVia String   @default("manual")
  createdAt  DateTime @default(now())

  @@index([userId])
}
