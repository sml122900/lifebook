// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client"
  output          = "../lib/generated/prisma"
  // postgresqlExtensions: extensions 블록(아래) 사용을 위한 preview.
  // vector 가 어느 스키마에 있는지 Prisma 가 인지해야 향후 migrate 가
  // 올바른 위치에 EXTENSION 을 만든다. 기존 마이그(public 가정) 는
  // IF NOT EXISTS 라 Supabase 의 extensions 스키마 사전 설치와 충돌 X.
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  // Prisma 7 에서 url/directUrl 은 schema.prisma 가 아닌 prisma.config.ts
  // 의 datasource 블록에 정의 (DATABASE_URL = pooling 6543 +
  // ?pgbouncer=true&connection_limit=1, DIRECT_URL = direct 5432 for
  // migrate).
  // Supabase 는 vector 확장을 "extensions" 스키마에 사전 설치. Prisma 가
  // 향후 마이그 생성 시 이 위치를 가정. 로컬 Docker DB 는 public 에
  // vector 가 있어 어긋나지만, 기존 마이그가 IF NOT EXISTS 라 회귀 0.
  extensions = [vector(schema: "extensions")]
}

enum EventTier {
  verified
  suggested
}

enum EventCategory {
  anchor
  trigger
}

enum TriggerResponseStatus {
  confirmed
  dismissed
}

enum AIMessageRole {
  user
  assistant
}

enum TokenOrderStatus {
  pending
  paid
  failed
  canceled
}

// 실물 상품 주문 상태. 토큰(TokenOrderStatus)과 달리 paid 이후 배송 이행
// 단계가 이어진다. v1(6/19 테스트)은 paid 까지만 도달하고 preparing~delivered
// 는 관리자 수동(변경 UI 없음, enum 만 보유).
enum ProductOrderStatus {
  pending // 결제창 진입(미결제)
  paid // 결제 승인 — 주문 접수
  preparing // 제작/준비(발주 착수) — 이후 환불 불가
  shipped // 발송(송장)
  delivered // 배송 완료
  failed
  canceled
  refunded // 환불 완료(발주 전 환불)
}

enum RoomMemberRole {
  owner
  member
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // domain fields
  birthYear Int?
  region    String?

  // 전역 AI 모델 선택(라이브 응답: companion·다듬기·튜토리얼·회상 어시스턴트).
  // "haiku"|"sonnet"|"opus". 기본 haiku(현행 라이브 기본). 추출은 이 값과 무관히
  // 항상 sonnet 고정. lib/ai-model.ts(상수)·lib/user-ai-model.ts(읽기/쓰기).
  aiModel String @default("haiku")

  // explicit consent timestamps (Phase 3.3)
  termsConsentAt            DateTime?
  privacyConsentAt          DateTime?
  overseasTransferConsentAt DateTime?
  // 동의 버전 (Phase 7b+). 기존 사용자 = 1(레거시), 신규·재동의 = 2+.
  // CURRENT_CONSENT_VERSION(lib/consent-version.ts)과 비교해 게이트 통과.
  privacyConsentVersion     Int @default(1)

  // Phase 4.5: marks the user as done with onboarding (completed or
  // fully skipped). Used to soft-route new users to /onboarding only once.
  onboardingCompletedAt DateTime?

  // Phase L2(+) — 인생 기록 카테고리 중 사용자가 "건너뛰기"를 누른 항목.
  // nextUnansweredCategory 가 *답함 ∪ 건너뜀* 모두를 건너뛴 채로 다음
  // 진짜 미답을 찾도록 사용. 인덱스 카드에는 "건너뜀" 으로 별도 표시.
  // 사용자가 같은 카테고리에 답하면 upsertLifeEvent 가 자동으로 셋에서 제거.
  skippedLifeCategories LifeCategory[] @default([])

  // null = OAuth 전용 계정. Credentials 가입 시에만 채워짐.
  // ★ 절대 평문 저장 금지 — bcrypt hash 만 저장.
  passwordHash String?

  createdAt DateTime @default(now())

  accounts              Account[]
  sessions              Session[]
  profile               LifeProfile?
  memories              UserMemory[]
  triggerResponses      TriggerResponse[]
  conversations         AIConversation[]
  wallet                TokenWallet?
  tokenTxs              TokenTransaction[]
  tokenOrders           TokenOrder[]
  ownedRooms            SharedRoom[]       @relation("SharedRoomOwner")
  roomMemberships       RoomMember[]
  invitesCreated        RoomInvite[]       @relation("InviteCreator")
  comments              Comment[]
  sharedMemoriesCreated SharedMemory[]     @relation("SharedMemoryCreator")
  sharedMemoriesEdited  SharedMemory[]     @relation("SharedMemoryEditor")
  timemachineMonths     TimemachineMonth[]
  attendances           UserAttendance[]
  reactions             MemoryReaction[]
  feedSeen              FamilyFeedSeen?
  people                Person[]
  photos                Photo[]
  productOrders         ProductOrder[]
  companionSessions     CompanionSession[]
  poster                Poster?
}

// P2 — 포스터 작업본. 유저당 1개("작업중 포스터").
//
// selections : 사용자가 고른 사건들 [{eventId, type:"node"|"memo", order}].
//   포스터에 넣을 것만 들어가고, 제외한 사건은 배열에 없다. order 는 시간순
//   기본(필요시 조정). type 은 P1 1차 분류를 사용자가 정정한 최종값.
// template/design : P5 맞춤 디자인 자리(배경 종·색 등). 지금은 비워둠.
//
// P1 후보(분류·우선순위)는 임시(매번 AI 계산)라 저장 안 함. 여기엔 사용자가
// *확정*한 선택만 영속한다. P4 SVG 합성이 이 selections 를 읽어 렌더.
model Poster {
  id         String   @id @default(cuid())
  userId     String   @unique
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  selections Json     @default("[]")
  template   String?
  design     Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LifeProfile {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests       String[]
  schools         String[]
  residences      String[]
  parentsInfo     String?
  siblings        String?
  closeFriends    String?
  hobbies         String?
  favMovies       String[]
  favGames        String[]
  favMusic        String[]
  // 온보딩 장소 매핑 — [{placeName,placeAddress,lat,lng,placeSource}]. 소비처: 미구현(나중 map/poster용)
  residencePlaces Json?
  schoolPlaces    Json?
  updatedAt       DateTime @updatedAt
}

// embedding is a pgvector(1024) column matching voyage-3.5 output.
// Prisma can't express the vector type natively, so it's Unsupported —
// day-to-day reads/writes go through raw SQL (see lib/triggers.ts).
model Event {
  id               String                       @id @default(cuid())
  year             Int
  month            Int?
  title            String
  description      String?
  tier             EventTier
  category         EventCategory
  domain           String
  region           String                       @default("KR")
  sourceName       String?
  sourceUrl        String?
  createdAt        DateTime                     @default(now())
  embedding        Unsupported("vector(1024)")?
  memories         UserMemory[]
  triggerResponses TriggerResponse[]
  conversations    AIConversation[]

  @@index([year])
}

// Phase 8.2 — paid token wallet. balance is a cached running total
// that MUST equal SUM(tokenTxs.delta) for the same userId; every
// mutation is done inside a $transaction that updates both rows
// together. reconcileBalance() in lib/tokens/wallet.ts checks the
// invariant on demand for audits.
// ⚠️ Every read / write is userId-scoped. signup grant is idempotent
// — wallet's @unique(userId) is the gate.
model TokenWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int // signed: +grant/topup/refund, -ai_charge
  reason    String // "signup_grant" | "ai_charge" | "topup" | "refund"
  refId     String? // payment id, AI message id, etc.
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Phase 9.1 — shared room for family / partner co-viewing.
//
// Privacy model:
//   - Personal memories stay owned by their author; the room only
//     gives other members read access (no edit).
//   - Joining requires explicit consent — RoomMember.consentAt must
//     be set before any read-on-behalf-of-room happens. The owner
//     gets consentAt at creation time; invited members fill it in
//     during the Phase 9.2 join flow.
// ⚠️ Every room-scoped read MUST verify the requesting user has a
// RoomMember row for that roomId with consentAt != null.
model SharedRoom {
  id             String           @id @default(cuid())
  name           String
  ownerId        String
  owner          User             @relation("SharedRoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members        RoomMember[]
  invites        RoomInvite[]
  comments       Comment[]
  reactions      MemoryReaction[]
  sharedMemories SharedMemory[]
  createdAt      DateTime         @default(now())

  @@index([ownerId])
}

model RoomMember {
  id        String         @id @default(cuid())
  roomId    String
  room      SharedRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      RoomMemberRole
  consentAt DateTime? // null = invited but hasn't agreed yet
  joinedAt  DateTime       @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

// Phase 9.2 — invite links. token is 256-bit entropy, base64url; it's
// the only handle ever exposed to the URL (no sequential ids). Just
// holding a link is NOT membership — the recipient must consent at
// /invite/[token]. Expiry / single-use are intentionally deferred.
model RoomInvite {
  id        String     @id @default(cuid())
  token     String     @unique
  roomId    String
  room      SharedRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  invitedBy String
  inviter   User       @relation("InviteCreator", fields: [invitedBy], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([roomId])
}

// Phase 9.5 — co-authored memory belonging to a room.
//
// Unlike UserMemory (one author, room sees a copy), SharedMemory is
// room-owned: any consented member may edit it, delete is reserved
// for the original author or the room owner (enforced in 9.6's
// helpers). lastEditedBy lets the UI surface who touched it most
// recently without a separate audit table.
// ⚠️ Every read MUST scope by roomId AND verify the requester is a
// consented member of that room.
model SharedMemory {
  id             String     @id @default(cuid())
  roomId         String
  room           SharedRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  year           Int
  month          Int?
  title          String
  content        String?
  // Nullable + SetNull: when an author withdraws, the room keeps the
  // co-authored memory; UI surfaces "탈퇴한 사용자" for null author.
  createdById    String?
  createdBy      User?      @relation("SharedMemoryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastEditedById String?
  lastEditedBy   User?      @relation("SharedMemoryEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([roomId, year])
}

// Phase 9.4 — comments on memories inside a room. targetType lets the
// same model serve both UserMemory (open scope) and SharedMemory
// (Phase 9.5+) without two parallel tables.
// ⚠️ Every read MUST verify the requester is a consented member of
// the comment's roomId. The room scope is the privacy boundary —
// never query by targetType+targetId alone.
model Comment {
  id         String     @id @default(cuid())
  roomId     String
  room       SharedRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  targetType String // "user_memory" | "shared_memory" (later)
  targetId   String
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime   @default(now())

  @@index([roomId, targetType, targetId])
  @@index([authorId])
}

// 동기부여 ② — 감정 스탬프 (가벼운 한 탭 반응). Comment 와 같은
// polymorphic (targetType/targetId) 패턴 — UserMemory 를 가리킨다.
//
// race-safe 토글: @@unique([roomId, targetType, targetId, authorId, stamp])
// 가 단일 결정자. "켜기" = create (P2002 → 이미 있음, 무시), "끄기" =
// deleteMany (count 0 → 이미 없음, 무시). 동시 클릭에도 idempotent.
// 한 사람이 한 추억에 stamp 종류별로 최대 1개 (종류는 여러 개 가능).
//
// 반응은 **룸별**(roomId 포함)로 분리한다. 같은 추억이 여러 룸에 보여도
// 룸마다 독립적으로 반응 — 저장(unique)·조회(listReactionsByTarget 의
// roomId 필터)가 같은 기준이라 "눌러도 안 되는" 먹통이 없고, 룸이
// 프라이버시 경계로 유지된다(A 룸 반응이 B 룸에 새지 않음).
// ⚠️ 모든 쓰기는 roomId 동의 멤버십 + 대상이 그 룸에서 보이는지 확인.
model MemoryReaction {
  id         String     @id @default(cuid())
  roomId     String
  room       SharedRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  targetType String // "user_memory" (shared_memory 는 추후)
  targetId   String
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  stamp      String // "touched" | "remember" | "proud" | "thanks"
  createdAt  DateTime   @default(now())

  @@unique([roomId, targetType, targetId, authorId, stamp])
  @@index([roomId, targetType, targetId])
  @@index([authorId])
}

// 동기부여 ② — 가족 소식 "읽음" 추적. 사용자당 1행 (userId @unique).
// 새것 판정 = 활동(반응/기록) createdAt > 해당 seenAt.
//   - reactionsSeenAt : 내 기록에 달린 가족 반응을 마지막으로 본 시각 (어르신)
//   - recordsSeenAt   : 가족의 새 이야기를 마지막으로 본 시각 (자녀)
// 첫 생성 시 now() 라 과거 활동이 소급으로 "새것" 폭주하지 않는다.
model FamilyFeedSeen {
  id              String   @id @default(cuid())
  userId          String   @unique
  user            User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactionsSeenAt DateTime @default(now())
  recordsSeenAt   DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

// Phase 8.5 — top-up order tracking. id doubles as the orderId we
// send to Toss. Amount + tokens are recorded at PENDING create from
// the server-side package definition, so the client can't bend either
// later. paymentKey @unique means the same Toss payment cannot be
// settled twice.
model TokenOrder {
  id         String           @id @default(cuid())
  // Nullable + SetNull: paid orders are retained for commerce-law
  // audit (5y); on withdrawal, userId is anonymized to null and the
  // record stays. Pending/failed/canceled are deleted in the action.
  userId     String?
  user       User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  packageId  String
  krw        Int
  tokens     Int
  status     TokenOrderStatus @default(pending)
  paymentKey String?          @unique
  approvedAt DateTime?
  failedAt   DateTime?
  failReason String?
  createdAt  DateTime         @default(now())
  updatedAt  DateTime         @updatedAt

  @@index([userId])
}

// 실물 상품 주문 (포스터·부적·책). 토큰 결제 인프라(confirmTossPayment)는
// 공용 재사용하되, 적립이 아니라 배송지 스냅샷 + 이행 상태를 기록하므로
// TokenOrder 와 분리한 별도 모델이다.
//
// 결제완료(paid+) 주문은 전자상거래법상 5년 보존 — TokenOrder 와 동일하게
// userId nullable + SetNull 로 탈퇴 시 익명화하고 레코드는 남긴다.
// pending/failed/canceled 는 탈퇴 액션에서 삭제 대상.
//
// 금액: 클라가 보낸 금액은 절대 신뢰 안 함. 서버가 상수(lib/commerce/products)
// 단가로 unitKrw 를 스냅샷하고 totalKrw = unitKrw*quantity + 배송비를 계산.
// settle 시 totalKrw === tossAmount 대조 후에만 paid. paymentKey @unique 로
// 같은 결제 두 번 정산 불가(TokenOrder 와 동일 idempotency).
model ProductOrder {
  id     String  @id @default(cuid())
  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  // 카탈로그 스냅샷 (lib/commerce/products 상수 id). v1 수량은 항상 1.
  productId String // "poster" | "charm" | "book"
  optionId  String? // 향후 옵션 확장용 (v1 미사용)
  quantity  Int     @default(1)
  unitKrw   Int // 주문 시점 단가 스냅샷
  shippingKrw Int   @default(0) // 배송비 스냅샷 (균일)
  totalKrw  Int // 서버 계산 = unitKrw*quantity + shippingKrw

  // 배송지 스냅샷 (User 에 구조화 주소 없음 — 주문별 보관이 법적 발송 기록)
  recipientName  String
  recipientPhone String
  postalCode     String?
  address1       String
  address2       String?
  deliveryMemo   String?

  // 결제
  status      ProductOrderStatus @default(pending)
  paymentKey  String?            @unique
  approvedAt  DateTime?
  failedAt    DateTime?
  failReason  String?
  paymentLive Boolean            @default(false) // 라이브 결제 여부(false=테스트모드)

  // 포스터 주문 스냅샷 — 주문 시점의 PosterCompose props({ownerName,nodes,memos}).
  // 관리자 발주 시 이 스냅샷으로 P7-a export(주문 후 편집과 무관하게 고정).
  // charm/book 은 null.
  posterSnapshot Json?

  // 환불(발주 전까지) — 사용자가 요청 → 관리자가 처리.
  refundRequestedAt DateTime?
  refundedAt        DateTime?
  refundReason      String?

  // 배송 이행 (관리자 수동 — /admin/orders 에서 입력)
  trackingCarrier String?
  trackingNumber  String?
  shippedAt       DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// Phase 7.5 — persisted memory conversation per (user, event). The
// first assistant message holds the AI-generated guided questions;
// later messages alternate user answers and (optionally) follow-up
// assistant replies. Reloading /memory/[eventId] reuses the same
// conversation so the user sees the same questions.
// ⚠️ All reads MUST scope by userId.
model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]

  @@unique([userId, eventId])
  @@index([userId])
}

model AIMessage {
  id             String         @id @default(cuid())
  conversationId String
  conversation   AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role           AIMessageRole
  content        String
  inputTokens    Int?
  outputTokens   Int?
  // Phase 8.3 — null = not yet settled against the wallet. Charge is
  // done per memory cycle (guided + summary together), so multiple
  // assistant messages may flip from null → now() in one transaction.
  chargedAt      DateTime?
  createdAt      DateTime       @default(now())

  @@index([conversationId])
}

// Phase 6.8 — per-user response to a suggested trigger event.
// confirmed = user keeps it on the timeline (Phase 7 will hang
// memories off these), dismissed = hide from future suggestions.
// ⚠️ Every read MUST scope by userId; never expose another user's row.
model TriggerResponse {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status    TriggerResponseStatus
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, eventId])
  @@index([userId])
}

// Memories default to private. Phase 9 will introduce shared visibility
// ("family", etc.); every read path MUST scope by userId until then.
//
// createdVia 값:
//   - "manual"            : Phase 7 이전 수동 입력
//   - "ai_chat"           : Phase 7 가이드 대화로 저장
//   - "timemachine_event" : Phase T6 — 타임머신에서 "남기기" 누른 사건 메모
//                           (monthEventId 가 채워짐, title 은 MonthEvent.title 비정규화)
//   - "timemachine_month" : Phase T6 — 타임머신 그 달 전체 회고
//                           (monthEventId=null, title="YYYY년 M월 회고")
//   - "timemachine_assistant" : Phase V3 — 비서 답을 "내 타임라인에 추가" 한 메모
//   - "life_event"        : Phase L1 — 인생 연혁(v3) 이벤트. eventYear/eventTitle
//                           등 life_event 전용 필드가 채워지며, year/month/title 은
//                           기존 코드 호환을 위해 같은 값으로 미러링한다.
model UserMemory {
  id           String      @id @default(cuid())
  userId       String
  user         User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId      String?
  event        Event?      @relation(fields: [eventId], references: [id])
  // T6 — 타임머신 사건 메모는 MonthEvent 를 가리킴. SetNull 이라 시드
  // 재실행으로 MonthEvent 가 갈려도 사용자 추억 행은 살아남고 title 만
  // 비정규화로 유지된다.
  monthEventId String?
  monthEvent   MonthEvent? @relation(fields: [monthEventId], references: [id], onDelete: SetNull)
  year         Int
  month        Int?
  title        String
  content      String?
  visibility   String      @default("private")
  createdVia   String      @default("manual")
  createdAt    DateTime    @default(now())

  // Phase L1 — 인생 연혁(v3) 전용 컬럼. createdVia="life_event" 일 때만
  // 채워지고 그 외 행에서는 모두 NULL. 기존 year/month/title 컬럼은 그대로
  // 두고(NOT NULL 유지), life_event 행에서는 동일 값으로 미러링한다 —
  // 가족 룸(listRoomMemories)·진척 시각화·반응이 기존 컬럼 기준으로
  // 작동하므로 추가 코드 없이 자동 호환.
  eventTitle String?
  eventYear  Int?
  eventMonth Int?
  precision  EventPrecision?
  category   LifeCategory?

  // Phase L2(+) — 기간(SCHOOL/WORK/MILITARY/RESIDENCE)의 끝 연도. life_event
  // 시작 행에만 채워짐. 시간축 렌더 시 endYear 있는 행은 "시작"·"끝" 두 점
  // 으로 split(같은 메모리 id 공유 → 룸 공유·반응은 한 단위로 유지).
  endYear  Int?
  // 2026-06-07 — 기간의 끝 월(선택). endYear 가 있을 때만 의미가 있고,
  // 채워지면 시간축의 "끝" 점이 EXACT(큰 채움 점, 정확한 시점)로 보이고
  // 라벨이 "YYYY년 MM월" 로 표시된다. null 이면 기존처럼 APPROXIMATE 끝 점.
  endMonth Int?

  // 2026-06-12 — 문장 다듬기(맞춤법만). 원문(content)은 영구 보존, AI 가
  // 맞춤법·띄어쓰기·명백한 오타만 교정한 글을 refinedText 에 따로 저장.
  // displayRefined=true 일 때만 연혁·상세에서 refinedText 우선 표시.
  // 사용자가 content 를 직접 수정하면 세 필드 모두 초기화(stale 방지).
  refinedText    String?
  refinedAt      DateTime?
  displayRefined Boolean   @default(false)

  // Phase 7b — 음성 녹음 저장. recordings 버킷 경로(서버사이드 signed URL 발급).
  // content(STT 텍스트)와 독립 — 둘 다 채워지거나, 텍스트만 있거나, 둘 다 null 가능.
  audioPath String?

  // Phase Place — 장소 매칭. life_event(특히 BIRTH·KINDERGARTEN·학령기 4종·
  // MILITARY·WORK) 행에서 사용자가 네이버/구글 지도 검색으로 고른 장소.
  // 기존 행은 모두 null — 무영향. 향후 다른 createdVia(timemachine_event)
  // 에서도 같은 컬럼을 재사용할 수 있도록 life_event 전용 prefix 안 붙임.
  //   placeName    : "강원도 춘천시 근화동" 같은 사람-읽기 라벨 (UI 표시용)
  //   placeAddress : 더 자세한 주소 (있으면)
  //   lat / lng    : 지도 핀 위치 (네이버는 KATEC→WGS84 변환 후 저장)
  //   placeSource  : "naver" | "google" — 지도 새 탭 링크 분기에 사용
  placeName    String?
  placeAddress String?
  lat          Float?
  lng          Float?
  placeSource  String?

  // Phase 10 Phase 2 — 통녹음 분할. 원본 free_recording 이 부모, 세그먼트
  // (life_event) 가 자식. SetNull: 원본 삭제 시 세그먼트 parentMemoryId 만
  // null 로 남고 세그먼트 자체는 생존 (사용자 이야기 보존 우선).
  parentMemoryId String?
  parentMemory   UserMemory?  @relation("SegmentSource", fields: [parentMemoryId], references: [id], onDelete: SetNull)
  childMemories  UserMemory[] @relation("SegmentSource")

  // Phase P1 — 이 이벤트에 연결된 인물 링크. life_event 행에만 만들어지지만
  // 모델 측 제약은 createdVia 를 강제하지 않는다(헬퍼에서만 강제). cascade
  // delete 로 메모리 삭제 시 인물 링크도 함께 정리.
  personEvents PersonEvent[]
  // Phase Photo — 이 메모리에 첨부된 사진(N장). life_event 첨부형 + 독립
  // 사진(createdVia="photo")형 둘 다 같은 1:N 구조 재사용. cascade delete
  // 로 메모리 삭제 시 Photo row 도 정리(Storage 파일은 별도 삭제 필요).
  photos       Photo[]
  // 장소 1:N — 한 사건에 여러 장소(MemoryPlace). 기존 평면 5컬럼
  // (placeName/placeAddress/lat/lng/placeSource)은 호환·롤백 위해 유지하고,
  // 새 장소는 이 관계로 쌓는다. cascade delete 로 메모리 삭제 시 정리.
  places       MemoryPlace[]
  // Phase E2 — 시대 사건 클릭 담기 중복 차단은 DB-only partial unique
  // index 로 강제됨 ("UserMemory_userId_monthEventId_createdVia_key" in
  // migration 20260608000000_era_event_unique). Prisma `@@unique` 는
  // partial WHERE 절을 표현하지 못해 schema 에 직접 못 적음. 코드는
  // P2002 catch 패턴 — 클라이언트 compound where 헬퍼 없이도 안전.

  // Phase companion — 동반자 세션 추출 초안. isDraft=true 행은 가족
  // 검토 전까지 타임라인·연혁 목록에서 제외. 승인 → isDraft=false(live).
  isDraft            Boolean           @default(false)
  companionSessionId String?
  companionSession   CompanionSession? @relation(fields: [companionSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  // Phase L1 — 인생 연혁 화면(L3)에서 사용자별 life_event 시간순 정렬용.
  @@index([userId, eventYear, eventMonth])
  @@index([parentMemoryId])
}

// Phase T1 (타임머신) — 월별 사건 + 차트 음악.
//
// 노출 규칙 (lib/timemachine.ts 의 getMonthScreen 참조):
//   - 일반 항목 (isPeriod=false): year/month 정확히 일치하는 달에만 노출.
//   - 기간 항목 (isPeriod=true): startYear*12+startMonth ≤ target*12+M
//     ≤ endYear*12+endMonth 인 모든 달에 노출. 유행(TREND)·해외음악
//     (INTERNATIONAL) 이 주로 기간 항목.
//
// 시드 데이터: phase/seed-timemachine.ts (Phase T2 에서 적재).
// 사실(사건명·아티스트·순위)만 다룸 — 저작권 보호 콘텐츠(가사·이미지)
// 는 절대 저장하지 않는다.

enum EventSection {
  POLITICS_SOCIETY
  CULTURE
  SPORTS
  TREND
}

enum EventTag {
  LIFESTYLE
  YOUTH
}

enum Confidence {
  VERIFIED
  APPROX
}

enum SongOrigin {
  DOMESTIC
  INTERNATIONAL
}

// Phase L1 — 인생 연혁(v3) 이벤트의 시점 정확도.
//   EXACT       : 사용자가 정확한 연/월을 기억하는 앵커 (예: "1972.3 초등 입학")
//   APPROXIMATE : 추정만 가능한 사이 이벤트 (예: "대학 1학년쯤")
enum EventPrecision {
  EXACT
  APPROXIMATE
}

// Phase L1 — 인생 연혁 카테고리.
// 통합 테스트 후 10개 학령기 분리·기타 정리(2026-06-02 v3.1):
//   - SCHOOL(통합) → ELEMENTARY/MIDDLE/HIGH/UNIVERSITY 4개로 쪼갬
//   - CHILDHOOD → KINDERGARTEN(어린이집·유치원) 으로 재정의
//   - RESIDENCE(큰 이사) / OTHER(그 외) 삭제 — 자유 추가는 L4 manage 영역
// 마이그레이션: 기존 SCHOOL→ELEMENTARY, CHILDHOOD→KINDERGARTEN, RESIDENCE/OTHER 행 삭제.
// 카테고리 추가가 필요하면 마이그레이션 동반.
enum LifeCategory {
  BIRTH // 출생
  KINDERGARTEN // 어린이집·유치원
  ELEMENTARY // 초등학교
  MIDDLE // 중학교
  HIGH // 고등학교
  UNIVERSITY // 대학교
  MILITARY // 군대
  WORK // 첫 직장
  RELATIONSHIP // 결혼
  FAMILY // 자녀
}

model MonthEvent {
  id          String       @id @default(cuid())
  year        Int?
  month       Int?
  section     EventSection
  tag         EventTag?
  title       String
  description String       @default("")
  eventDate   String?
  isPeriod    Boolean      @default(false)
  startYear   Int?
  startMonth  Int?
  endYear     Int?
  endMonth    Int?
  confidence  Confidence   @default(APPROX)
  source      String?
  memories    UserMemory[] // T6 — 사용자가 이 사건을 "남기기" 한 추억들
}

// @deprecated Phase T6 — 타임머신 저장이 UserMemory 로 이전됨 (한 달치
// 가 여러 UserMemory row 로 정규화). 새 데이터는 이 테이블에 들어가지
// 않는다. T3 보완 시점에 작성된 행이 남아있을 수 있어 모델은 유지하지만,
// 사용자 검토 후 별도 cleanup phase 에서 drop 예정.
model TimemachineMonth {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year       Int
  month      Int
  monthStory String   @default("")
  keptEvents Json     @default("[]")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId])
}

// Phase A1 — 매일 출석체크. 하루 1행만 (날짜 unique). KST 기준 YYYY-MM-DD
// 문자열로 date 저장 — 타임존 비교 헷갈림 차단 + 인덱싱 단순.
//
// 정책:
//   - 매일 5토큰 (DAILY_CREDIT) — TokenTransaction reason="daily_attendance"
//   - 7의 배수 streak 마다 +30토큰 (BONUS_CREDIT, BONUS_EVERY_DAYS=7)
//     — reason="attendance_streak_bonus"
//   - 하루라도 거르면 streak = 1 로 리셋.
//   - 거른 날은 비난·압박 표현 X. 매일 기본 5토큰은 계속 받음.
//
// race-safe: @@unique([userId, date]) 가 단일 결정자. 동시 두 요청 →
// 하나만 create 성공, 다른 하나는 P2002 → "이미 출석" 반환.
model UserAttendance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       String // KST "YYYY-MM-DD"
  streak     Int // 이 날 출석 후 연속 일수 (1 부터)
  bonusToken Int      @default(0) // 이 날 받은 보너스 (0 또는 BONUS_CREDIT)
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model ChartSong {
  id           String     @id @default(cuid())
  origin       SongOrigin
  rank         Int?
  title        String
  artist       String     @default("")
  year         Int?
  month        Int?
  isPeriod     Boolean    @default(false)
  startYear    Int?
  startMonth   Int?
  endYear      Int?
  endMonth     Int?
  youtubeQuery String     @default("")
  eraColor     String     @default("2020s")
  confidence   Confidence @default(APPROX)
}

// Phase P1 — 인생에 등장하는 인물(친구·동료·가족 등). 사용자 한 명이 여러
// 인물을 보유하고, 각 인물은 0~N 개 life_event 와 PersonEvent 로 연결된다.
//
// 프라이버시 (CLAUDE.md "타인 이름은 별명/이니셜 입력 옵션 제공 - 최소
// 수집"): 실명 강제 X. 사용자가 별명을 넣으면 그대로 저장. 자유 텍스트만
// 다루며 민감 정보(건강·정치·종교)는 유도하지 않음.
//
// ⚠️ 모든 읽기/쓰기는 userId-scope. 헬퍼(lib/people.ts) 가 단일 진입점.
model Person {
  id          String        @id @default(cuid())
  userId      String
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subjectType String        @default("person") // "person"|"location"|"thing"
  name        String // 필수, 최대 50자 (헬퍼에서 검증)
  relation    String? // "초등 친구", "직장 동료" 등 자유 텍스트, 최대 30자 (person 전용)
  birthYear   Int? // 인물 출생년도 (person 전용)
  category    String? // 관계 분류 — 가족·친척·친구·직장·이웃·기타 (person 전용)
  metYear     Int? // 처음 만난 연도 (person 전용)
  memo        String? // 메모
  // location 전용 — 장소 좌표 (PlaceSearchInput 으로 지정). person/thing 은 null.
  lat          Float?
  lng          Float?
  placeAddress String?
  placeSource  String? // "naver"|"google"
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  events      PersonEvent[]

  // Phase companion — isDraft=true = 동반자 추출 후 가족 검토 대기 중.
  isDraft            Boolean           @default(false)
  companionSessionId String?
  companionSession   CompanionSession? @relation(fields: [companionSessionId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([userId, subjectType])
}

// Phase P1 — Person ↔ UserMemory 다대다 조인 테이블.
//
// 정책:
//   - personId·memoryId 둘 다 같은 userId 소유여야 함 (헬퍼에서 검증).
//   - memoryId 는 createdVia="life_event" 인 UserMemory 만 허용 (헬퍼).
//     timemachine_event 등 다른 종류 메모리에는 인물 못 붙임. 인물은 *인생*
//     이벤트에만.
//   - userId 는 권한 체크용 비정규화 필드. 반드시 person.userId 와 일치.
//   - 같은 (인물, 이벤트) 중복 금지 — @@unique 가 단일 결정자, idempotent
//     링크는 헬퍼에서 P2002 catch.
//   - cascade: Person 삭제 또는 UserMemory 삭제 시 함께 정리.
model PersonEvent {
  id        String     @id @default(cuid())
  personId  String
  person    Person     @relation(fields: [personId], references: [id], onDelete: Cascade)
  memoryId  String
  memory    UserMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  userId    String // 권한 체크용 (반드시 person.userId 와 일치)
  createdAt DateTime   @default(now())

  @@unique([personId, memoryId])
  @@index([userId])
  @@index([memoryId])
}

// Phase Photo — 사용자의 사진 파일 메타 + Supabase Storage 경로.
// 옵션 C 패턴: 모든 사진은 UserMemory(life_event 또는 createdVia="photo")
// 한 행에 매여 있고 한 메모리에 여러 장 가능. 인물·장소·날짜는 메모리에
// 매김(자동 호환). 사진 파일 자체는 Supabase Storage 의 photos 버킷에
// {userId}/{photoId}.{ext} 경로로 저장 — service_role 키로 접근, RLS X.
//
// 권한 모델: userId 가 단일 결정자. 모든 read/write 헬퍼가 userId 첫 인자.
// memory.userId 와 photo.userId 는 항상 같아야 함(헬퍼에서 강제).
//
// cascade:
//   - User 삭제 → Photo cascade (DB row). Storage 파일은 별도 cleanup.
//   - UserMemory 삭제 → Photo cascade (메모리 단위 그룹).
//
// 정합성 위험: Storage upload 후 DB row 생성 실패 시 orphan 파일. 후속
// cleanup cron 또는 transaction 래핑(현재 supabase-js 가 PG transaction
// 안 들어감 — 업로드 후 DB 생성 실패면 try/catch 로 Storage 롤백).
model Photo {
  id          String     @id @default(cuid())
  userId      String
  user        User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  memoryId    String
  memory      UserMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  storagePath String // "{userId}/{photoId}.{ext}" — Storage 키
  mimeType    String // image/jpeg | image/png | image/webp
  fileBytes   Int // 용량 (10MB 제한은 라우트에서)
  width       Int? // 메타 (썸네일·레이아웃 — 후속에 EXIF 추출)
  height      Int?
  caption     String? // 사진 1장 캡션 (선택)
  takenAt     DateTime? // EXIF 또는 사용자 입력 (선택)
  // Phase Photo (4단계+) — 기간 이벤트(학교/군대/직장)는 시작·끝 두 점으로
  // 그려지는데(TimelineView expandPeriods), 사진은 memoryId 한곳에 붙어 양쪽에
  // 다 복제돼 보였다. 이 앵커로 어느 점에 띄울지 구분한다:
  //   "both"  : 시작·끝 둘 다 (기본 — 단일 시점 이벤트·기존 사진 모두 이 값)
  //   "start" : 시작 점에만 (입학/입대/입사 무렵)
  //   "end"   : 끝 점에만   (졸업/제대/퇴사 무렵)
  // 단일 시점 이벤트에선 의미 없음(항상 both 로 저장·전부 표시).
  periodAnchor String   @default("both")
  createdAt    DateTime  @default(now())

  @@index([userId, createdAt])
  @@index([memoryId])
}

// 장소 1:N — 한 사건(UserMemory)에 여러 장소.
//
// 기존 UserMemory 의 평면 장소 5컬럼(placeName/placeAddress/lat/lng/
// placeSource)은 삭제하지 않고 호환·롤백용으로 유지한다. 새 장소는 이
// 테이블에 1행씩 쌓고, sortOrder 로 표시 순서를 정한다. cascade delete
// 로 메모리 삭제 시 함께 정리.
//
// placeName 은 NOT NULL — 장소가 있을 때만 행을 만든다(validatePlace 정책:
// placeName 없으면 장소 미선택). placeSource 는 "naver" | "google".
model MemoryPlace {
  id           String     @id @default(cuid())
  memoryId     String
  memory       UserMemory @relation(fields: [memoryId], references: [id], onDelete: Cascade)
  placeName    String
  placeAddress String?
  lat          Float?
  lng          Float?
  placeSource  String?
  sortOrder    Int        @default(0)
  createdAt    DateTime   @default(now())

  @@index([memoryId])
}

// Phase companion — 음성 동반자 세션 저장.
//
// audioPaths: recordings 버킷의 tmp_{userId}_{ts}.webm 경로 배열.
// tmp_ 접두사는 업로드 라우트 관례일 뿐 — Supabase Storage 는 auto-delete 없음.
// 어르신 목소리는 대체 불가 자산. 파일 이동 없이 경로 그대로 영구 보존.
//
// transcriptJson: JSON stringified TranscriptMessage[]
//   [{speaker: "elder"|"companion", text: string}]
//   OPENING_TRIGGER(메타) 제외, 실제 대화만 기록.
//
// 연결:
//   UserMemory(createdVia="companion") — 원본 transcript 보관 행 (isDraft=false)
//   UserMemory(createdVia="life_event", isDraft=true) — 추출 초안 사건들
//   Person(isDraft=true) — 추출 초안 인물들
//
// 승인 흐름: isDraft=true → isDraft=false (live). 거절: delete.
model CompanionSession {
  id             String       @id @default(cuid())
  userId         String
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  transcriptJson String       @default("[]")
  audioPaths     String[]
  createdAt      DateTime     @default(now())

  memories    UserMemory[]
  draftPeople Person[]

  @@index([userId, createdAt])
}
