ANTHROPIC_API_KEY=""

# Voyage AI — trigger event embedding (Phase 6)
VOYAGE_API_KEY=""

# Auth.js v5 — generate with: npx auth secret
AUTH_SECRET=""

# 토스페이먼츠 — 토큰 단건 결제 (Phase 8.5)
# 발급: 토스페이먼츠 개발자센터(developers.tosspayments.com) → 내 개발정보 →
#       "테스트" 모드에서 클라이언트 키(test_ck_...) / 시크릿 키(test_sk_...).
# ⚠️ 둘 다 test_ 접두사 확인 — 운영키(live_) 섞이면 실제 청구됨.
# TOSS_CLIENT_KEY: 서버 page.tsx 가 읽어 마크업에 내려줌(공개용, NEXT_PUBLIC 아님).
# TOSS_SECRET_KEY: lib/tokens/toss.ts(서버)에서만 — 절대 브라우저로 나가지 않음.
TOSS_CLIENT_KEY=""
TOSS_SECRET_KEY=""

# 포스터 실물결제 라이브 플래그 (P7-b). 기본 OFF = 테스트모드(플로우 다 돌되
# 실청구 X). ON 조건 = 통신판매업 신고번호 + Toss 프로덕션 승인 둘 다 충족 후
# "true" 로(Toss 라이브 키 교체 동반). 미설정/그 외 값 = OFF.
POSTER_PAYMENT_LIVE_ENABLED=""

# 관리자 이메일 화이트리스트 (P7-b /admin/orders 접근). 쉼표 구분. 여기 적힌
# 로그인 이메일만 관리자 페이지(주문·발주·송장·환불)에 접근. 미설정=관리자 없음.
ADMIN_EMAILS=""

# Google OAuth — issue at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Phase Place — 장소 검색 + 지도 렌더 (네이버 / 구글)
#
# ⚠️ 키 분리 정책 — 서버용/클라용은 반드시 다른 키로 발급해야 함.
# 같은 키를 양쪽에 넣으면 서버 fetch 는 referrer 가 비어 차단되거나,
# 클라 SDK 가 referrer 제약을 만족 못해 인증 실패.
#
# ── [구글] 두 키 모두 Google Cloud Console 에서 발급 ───────────────
# GOOGLE_MAPS_API_KEY (서버 검색용)
#   · 사용 API: Places API (New) 만 허용
#   · Application restrictions: None (또는 서버 IP 제한)
#   · HTTP 리퍼러 제한 X — 서버 fetch 는 referrer 가 비어 차단됨
AUTH_NAVER_ID=""
AUTH_NAVER_SECRET=""
GOOGLE_MAPS_API_KEY=""
# NEXT_PUBLIC_GOOGLE_MAPS_API_KEY (클라 지도 SDK용)
#   · 사용 API: Maps JavaScript API 만 허용
#   · Application restrictions: HTTP referrers (http://localhost:3000/* + 운영 도메인)
#
# ── [네이버] 두 시스템은 완전히 다름 — 같은 키 절대 호환 X ─────────
# AUTH_NAVER_ID + AUTH_NAVER_SECRET (서버 검색 + 네이버 로그인 공용)
#   · 발급: developers.naver.com → 애플리케이션 → 사용 API "검색" + "네이버 로그인"
#   · 한 앱의 Client ID/Secret 하나로 검색 API 와 로그인을 함께 사용
#   · 검색 헤더: X-Naver-Client-Id / X-Naver-Client-Secret
#   · 로그인: Auth.js v5 가 AUTH_NAVER_ID/SECRET 를 자동 인식
# NEXT_PUBLIC_NAVER_MAP_CLIENT_ID (클라 지도 SDK용)
#   · 발급: console.ncloud.com → AI·NAVER API → Maps 활성화 (Web Dynamic Map)
#   · Web 서비스 URL 화이트리스트: http://localhost:3000 + 운영 도메인
#   · 신형 라벨 "X-NCP-APIGW-API-KEY-ID" 와 짝 → SDK 로드 파라미터 ?ncpKeyId=
#     (구형 ?ncpClientId= 는 신형 키와 호환 X)
NEXT_PUBLIC_NAVER_MAP_CLIENT_ID=""
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=""

# CLOVA Voice (TTS) — 음성 동반자 AI 응답 읽기 (Step 1)
# 발급: console.ncloud.com → AI·NAVER API → CLOVA Voice 활성화
#        → Sub Account → Access Key 발급 (Key ID + Secret)
# ⚠️ 서버 전용. NEXT_PUBLIC_ 접두사 절대 금지.
# ⚠️ CLOVA Speech(STT)의 X-CLOVASPEECH-API-KEY 와 완전히 다른 키 시스템.
# speaker/speed 기본값은 lib/clova-tts.ts TTS_CONFIG 에서 변경.
NCP_TTS_KEY_ID=""
NCP_TTS_KEY_SECRET=""
