// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum EventTier {
  verified
  suggested
}

enum EventCategory {
  anchor
  trigger
}

enum TriggerResponseStatus {
  confirmed
  dismissed
}

enum AIMessageRole {
  user
  assistant
}

enum TokenOrderStatus {
  pending
  paid
  failed
  canceled
}

enum RoomMemberRole {
  owner
  member
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?

  // domain fields
  birthYear Int?
  region    String?

  // explicit consent timestamps (Phase 3.3)
  termsConsentAt            DateTime?
  privacyConsentAt          DateTime?
  overseasTransferConsentAt DateTime?

  // Phase 4.5: marks the user as done with onboarding (completed or
  // fully skipped). Used to soft-route new users to /onboarding only once.
  onboardingCompletedAt DateTime?

  createdAt DateTime @default(now())

  accounts          Account[]
  sessions          Session[]
  profile           LifeProfile?
  memories          UserMemory[]
  triggerResponses  TriggerResponse[]
  conversations     AIConversation[]
  wallet            TokenWallet?
  tokenTxs          TokenTransaction[]
  tokenOrders       TokenOrder[]
  ownedRooms             SharedRoom[]    @relation("SharedRoomOwner")
  roomMemberships        RoomMember[]
  invitesCreated         RoomInvite[]    @relation("InviteCreator")
  comments               Comment[]
  sharedMemoriesCreated  SharedMemory[]  @relation("SharedMemoryCreator")
  sharedMemoriesEdited   SharedMemory[]  @relation("SharedMemoryEditor")
  timemachineMonths      TimemachineMonth[]
  attendances            UserAttendance[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model LifeProfile {
  id           String   @id @default(cuid())
  userId       String   @unique
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  interests    String[]
  schools      String[]
  residences   String[]
  parentsInfo  String?
  siblings     String?
  closeFriends String?
  hobbies      String?
  favMovies    String[]
  favGames     String[]
  favMusic     String[]
  updatedAt    DateTime @updatedAt
}

// embedding is a pgvector(1024) column matching voyage-3.5 output.
// Prisma can't express the vector type natively, so it's Unsupported —
// day-to-day reads/writes go through raw SQL (see lib/triggers.ts).
model Event {
  id          String                       @id @default(cuid())
  year        Int
  month       Int?
  title       String
  description String?
  tier        EventTier
  category    EventCategory
  domain      String
  region      String                       @default("KR")
  sourceName  String?
  sourceUrl   String?
  createdAt   DateTime                     @default(now())
  embedding         Unsupported("vector(1024)")?
  memories          UserMemory[]
  triggerResponses  TriggerResponse[]
  conversations     AIConversation[]

  @@index([year])
}

// Phase 8.2 — paid token wallet. balance is a cached running total
// that MUST equal SUM(tokenTxs.delta) for the same userId; every
// mutation is done inside a $transaction that updates both rows
// together. reconcileBalance() in lib/tokens/wallet.ts checks the
// invariant on demand for audits.
// ⚠️ Every read / write is userId-scoped. signup grant is idempotent
// — wallet's @unique(userId) is the gate.
model TokenWallet {
  id        String   @id @default(cuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  balance   Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TokenTransaction {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  delta     Int      // signed: +grant/topup/refund, -ai_charge
  reason    String   // "signup_grant" | "ai_charge" | "topup" | "refund"
  refId     String?  // payment id, AI message id, etc.
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
}

// Phase 9.1 — shared room for family / partner co-viewing.
//
// Privacy model:
//   - Personal memories stay owned by their author; the room only
//     gives other members read access (no edit).
//   - Joining requires explicit consent — RoomMember.consentAt must
//     be set before any read-on-behalf-of-room happens. The owner
//     gets consentAt at creation time; invited members fill it in
//     during the Phase 9.2 join flow.
// ⚠️ Every room-scoped read MUST verify the requesting user has a
// RoomMember row for that roomId with consentAt != null.
model SharedRoom {
  id             String         @id @default(cuid())
  name           String
  ownerId        String
  owner          User           @relation("SharedRoomOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  members        RoomMember[]
  invites        RoomInvite[]
  comments       Comment[]
  sharedMemories SharedMemory[]
  createdAt      DateTime       @default(now())

  @@index([ownerId])
}

model RoomMember {
  id        String         @id @default(cuid())
  roomId    String
  room      SharedRoom     @relation(fields: [roomId], references: [id], onDelete: Cascade)
  userId    String
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      RoomMemberRole
  consentAt DateTime?      // null = invited but hasn't agreed yet
  joinedAt  DateTime       @default(now())

  @@unique([roomId, userId])
  @@index([userId])
}

// Phase 9.2 — invite links. token is 256-bit entropy, base64url; it's
// the only handle ever exposed to the URL (no sequential ids). Just
// holding a link is NOT membership — the recipient must consent at
// /invite/[token]. Expiry / single-use are intentionally deferred.
model RoomInvite {
  id        String     @id @default(cuid())
  token     String     @unique
  roomId    String
  room      SharedRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  invitedBy String
  inviter   User       @relation("InviteCreator", fields: [invitedBy], references: [id], onDelete: Cascade)
  createdAt DateTime   @default(now())

  @@index([roomId])
}

// Phase 9.5 — co-authored memory belonging to a room.
//
// Unlike UserMemory (one author, room sees a copy), SharedMemory is
// room-owned: any consented member may edit it, delete is reserved
// for the original author or the room owner (enforced in 9.6's
// helpers). lastEditedBy lets the UI surface who touched it most
// recently without a separate audit table.
// ⚠️ Every read MUST scope by roomId AND verify the requester is a
// consented member of that room.
model SharedMemory {
  id             String     @id @default(cuid())
  roomId         String
  room           SharedRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  year           Int
  month          Int?
  title          String
  content        String?
  // Nullable + SetNull: when an author withdraws, the room keeps the
  // co-authored memory; UI surfaces "탈퇴한 사용자" for null author.
  createdById    String?
  createdBy      User?      @relation("SharedMemoryCreator", fields: [createdById], references: [id], onDelete: SetNull)
  lastEditedById String?
  lastEditedBy   User?      @relation("SharedMemoryEditor", fields: [lastEditedById], references: [id], onDelete: SetNull)
  createdAt      DateTime   @default(now())
  updatedAt      DateTime   @updatedAt

  @@index([roomId, year])
}

// Phase 9.4 — comments on memories inside a room. targetType lets the
// same model serve both UserMemory (open scope) and SharedMemory
// (Phase 9.5+) without two parallel tables.
// ⚠️ Every read MUST verify the requester is a consented member of
// the comment's roomId. The room scope is the privacy boundary —
// never query by targetType+targetId alone.
model Comment {
  id         String     @id @default(cuid())
  roomId     String
  room       SharedRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  targetType String     // "user_memory" | "shared_memory" (later)
  targetId   String
  authorId   String
  author     User       @relation(fields: [authorId], references: [id], onDelete: Cascade)
  content    String
  createdAt  DateTime   @default(now())

  @@index([roomId, targetType, targetId])
  @@index([authorId])
}

// Phase 8.5 — top-up order tracking. id doubles as the orderId we
// send to Toss. Amount + tokens are recorded at PENDING create from
// the server-side package definition, so the client can't bend either
// later. paymentKey @unique means the same Toss payment cannot be
// settled twice.
model TokenOrder {
  id          String           @id @default(cuid())
  // Nullable + SetNull: paid orders are retained for commerce-law
  // audit (5y); on withdrawal, userId is anonymized to null and the
  // record stays. Pending/failed/canceled are deleted in the action.
  userId      String?
  user        User?            @relation(fields: [userId], references: [id], onDelete: SetNull)
  packageId   String
  krw         Int
  tokens      Int
  status      TokenOrderStatus @default(pending)
  paymentKey  String?          @unique
  approvedAt  DateTime?
  failedAt    DateTime?
  failReason  String?
  createdAt   DateTime         @default(now())
  updatedAt   DateTime         @updatedAt

  @@index([userId])
}

// Phase 7.5 — persisted memory conversation per (user, event). The
// first assistant message holds the AI-generated guided questions;
// later messages alternate user answers and (optionally) follow-up
// assistant replies. Reloading /memory/[eventId] reuses the same
// conversation so the user sees the same questions.
// ⚠️ All reads MUST scope by userId.
model AIConversation {
  id        String      @id @default(cuid())
  userId    String
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  messages  AIMessage[]

  @@unique([userId, eventId])
  @@index([userId])
}

model AIMessage {
  id              String         @id @default(cuid())
  conversationId  String
  conversation    AIConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  role            AIMessageRole
  content         String
  inputTokens     Int?
  outputTokens    Int?
  // Phase 8.3 — null = not yet settled against the wallet. Charge is
  // done per memory cycle (guided + summary together), so multiple
  // assistant messages may flip from null → now() in one transaction.
  chargedAt       DateTime?
  createdAt       DateTime       @default(now())

  @@index([conversationId])
}

// Phase 6.8 — per-user response to a suggested trigger event.
// confirmed = user keeps it on the timeline (Phase 7 will hang
// memories off these), dismissed = hide from future suggestions.
// ⚠️ Every read MUST scope by userId; never expose another user's row.
model TriggerResponse {
  id        String                @id @default(cuid())
  userId    String
  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId   String
  event     Event                 @relation(fields: [eventId], references: [id], onDelete: Cascade)
  status    TriggerResponseStatus
  createdAt DateTime              @default(now())
  updatedAt DateTime              @updatedAt

  @@unique([userId, eventId])
  @@index([userId])
}

// Memories default to private. Phase 9 will introduce shared visibility
// ("family", etc.); every read path MUST scope by userId until then.
//
// createdVia 값:
//   - "manual"            : Phase 7 이전 수동 입력
//   - "ai_chat"           : Phase 7 가이드 대화로 저장
//   - "timemachine_event" : Phase T6 — 타임머신에서 "남기기" 누른 사건 메모
//                           (monthEventId 가 채워짐, title 은 MonthEvent.title 비정규화)
//   - "timemachine_month" : Phase T6 — 타임머신 그 달 전체 회고
//                           (monthEventId=null, title="YYYY년 M월 회고")
model UserMemory {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  eventId    String?
  event      Event?   @relation(fields: [eventId], references: [id])
  // T6 — 타임머신 사건 메모는 MonthEvent 를 가리킴. SetNull 이라 시드
  // 재실행으로 MonthEvent 가 갈려도 사용자 추억 행은 살아남고 title 만
  // 비정규화로 유지된다.
  monthEventId String?
  monthEvent   MonthEvent? @relation(fields: [monthEventId], references: [id], onDelete: SetNull)
  year       Int
  month      Int?
  title      String
  content    String?
  visibility String   @default("private")
  createdVia String   @default("manual")
  createdAt  DateTime @default(now())

  @@index([userId])
}

// Phase T1 (타임머신) — 월별 사건 + 차트 음악.
//
// 노출 규칙 (lib/timemachine.ts 의 getMonthScreen 참조):
//   - 일반 항목 (isPeriod=false): year/month 정확히 일치하는 달에만 노출.
//   - 기간 항목 (isPeriod=true): startYear*12+startMonth ≤ target*12+M
//     ≤ endYear*12+endMonth 인 모든 달에 노출. 유행(TREND)·해외음악
//     (INTERNATIONAL) 이 주로 기간 항목.
//
// 시드 데이터: phase/seed-timemachine.ts (Phase T2 에서 적재).
// 사실(사건명·아티스트·순위)만 다룸 — 저작권 보호 콘텐츠(가사·이미지)
// 는 절대 저장하지 않는다.

enum EventSection {
  POLITICS_SOCIETY
  CULTURE
  SPORTS
  TREND
}

enum EventTag {
  LIFESTYLE
  YOUTH
}

enum Confidence {
  VERIFIED
  APPROX
}

enum SongOrigin {
  DOMESTIC
  INTERNATIONAL
}

model MonthEvent {
  id          String       @id @default(cuid())
  year        Int?
  month       Int?
  section     EventSection
  tag         EventTag?
  title       String
  description String       @default("")
  eventDate   String?
  isPeriod    Boolean      @default(false)
  startYear   Int?
  startMonth  Int?
  endYear     Int?
  endMonth    Int?
  confidence  Confidence   @default(APPROX)
  source      String?
  memories    UserMemory[]  // T6 — 사용자가 이 사건을 "남기기" 한 추억들
}

// @deprecated Phase T6 — 타임머신 저장이 UserMemory 로 이전됨 (한 달치
// 가 여러 UserMemory row 로 정규화). 새 데이터는 이 테이블에 들어가지
// 않는다. T3 보완 시점에 작성된 행이 남아있을 수 있어 모델은 유지하지만,
// 사용자 검토 후 별도 cleanup phase 에서 drop 예정.
model TimemachineMonth {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  year        Int
  month       Int
  monthStory  String   @default("")
  keptEvents  Json     @default("[]")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@unique([userId, year, month])
  @@index([userId])
}

// Phase A1 — 매일 출석체크. 하루 1행만 (날짜 unique). KST 기준 YYYY-MM-DD
// 문자열로 date 저장 — 타임존 비교 헷갈림 차단 + 인덱싱 단순.
//
// 정책:
//   - 매일 5토큰 (DAILY_CREDIT) — TokenTransaction reason="daily_attendance"
//   - 7의 배수 streak 마다 +30토큰 (BONUS_CREDIT, BONUS_EVERY_DAYS=7)
//     — reason="attendance_streak_bonus"
//   - 하루라도 거르면 streak = 1 로 리셋.
//   - 거른 날은 비난·압박 표현 X. 매일 기본 5토큰은 계속 받음.
//
// race-safe: @@unique([userId, date]) 가 단일 결정자. 동시 두 요청 →
// 하나만 create 성공, 다른 하나는 P2002 → "이미 출석" 반환.
model UserAttendance {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date       String   // KST "YYYY-MM-DD"
  streak     Int      // 이 날 출석 후 연속 일수 (1 부터)
  bonusToken Int      @default(0) // 이 날 받은 보너스 (0 또는 BONUS_CREDIT)
  createdAt  DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model ChartSong {
  id           String     @id @default(cuid())
  origin       SongOrigin
  rank         Int?
  title        String
  artist       String     @default("")
  year         Int?
  month        Int?
  isPeriod     Boolean    @default(false)
  startYear    Int?
  startMonth   Int?
  endYear      Int?
  endMonth     Int?
  youtubeQuery String     @default("")
  eraColor     String     @default("2020s")
  confidence   Confidence @default(APPROX)
}
